---
import ProjectComponent from "./ProjectComponent.astro";
import Funkos from "../assets/projects/funkostore.png"
import Panaderia from "../assets/projects/panaderiaproject.png"
import Shortnest from "../assets/projects/shortnest.png"
import Shape1 from "../assets/shapes/shape.svg"
import Shape2 from "../assets/shapes/shape2.svg"
import Shape3 from "../assets/shapes/shape3.svg"
import type { ProjectComponentProps } from "../types";
import {useTranslations} from "../i18n/utils";
import {languageList} from "../i18n/ui";

const currentLang = Astro.currentLocale || "es"

const t = useTranslations(currentLang as keyof typeof languageList)

const projects: ProjectComponentProps[] = [
    {
        projectImage:{
            image: Panaderia,
            imgBg:"linear-gradient(135deg, #6b4f10 0%, #3d3020 50%, #1a1a2e 100%)"
        },
        projectText:{
            title:t("panaderiaTitle"),
            techstach:"Laravel, Blade Templates, PHP",
            description:t("panaderiaDesc"),
            shape: Shape1.src,
            githubUrl: "https://github.com/Alonso2002-jpg/Project-Panaderia-Laravel"
        },
        imgPosition: "left",
    },
    {
        projectImage:{
            image: Shortnest,
            imgBg:"linear-gradient(135deg, #2e2e3a 0%, #1f1f30 50%, #1a1a2e 100%)"
        },
        projectText:{
            title:"SHORTNEST",
            techstach:".NET, Vue.js, TypeScript",
            description:t("shortnestDesc"),
            shape: Shape3.src,
            githubUrl: "https://github.com/Alonso2002-jpg/ShortNest"
        },
        imgPosition: "right",
    }
]


---
<div class="projects-section">
    <div class="section-header">
        <h2 class="section-title">{t("sectionProjects")}</h2>
        <div class="section-line"></div>
    </div>
    {
        projects.map(projectProp => {
            return <ProjectComponent projectsProps={projectProp} />
        })
    }
</div>

<style>
    .projects-section {
        width: 100%;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        padding: 0 2rem 1.5rem 2rem;
        box-sizing: border-box;
    }

    .section-title {
        font-family: "Albert Sans", serif;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: #888;
        white-space: nowrap;
        margin: 0;
    }

    .section-line {
        flex: 1;
        height: 1px;
        background: linear-gradient(to right, #ccc, transparent);
    }
</style>