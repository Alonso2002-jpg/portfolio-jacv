---
import LineTitle from "./LineTitle.astro";
import AboutMeSection from "./AboutMeSection.astro";
import AvatarComponent from "./AvatarComponent.astro";
import MyImage from "../assets/my-jpg.png"
import SectionItem from "./SectionItem.astro";
import {useTranslations} from "../i18n/utils";
import {languageList} from "../i18n/ui";

const { currentLang } = Astro.props

const t = useTranslations(currentLang as keyof typeof languageList)
---

<div class="about-container">
    <div class="section-header">
        <h2 class="section-title">{t("sectionAbout")}</h2>
        <div class="section-line"></div>
    </div>
    <div class="container">
        <div class="content">
            <AboutMeSection>
                <AvatarComponent src={MyImage.src} alt={"Jorge Alonso Cruz Vera"} />
                <SectionItem title={t('aboutMe')} description={t('aboutMeDesc')} />
                <SectionItem title={t('experience')} description={t('experienceDesc')} />
            </AboutMeSection>
            <AboutMeSection>
                <SectionItem title={t('works')} description={t('worksDesc')} />
                <SectionItem title={t('skills')} description={t('skillsDesc')} />
                <SectionItem title={t('hobbies')} description={t('hobbiesDesc')} />
            </AboutMeSection>
        </div>
    </div>
</div>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Albert+Sans:ital,wght@0,300;1,300&family=Poiret+One&display=swap');
    .about-container {
        width: 100%;
        min-height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        font-family: "Albert Sans", serif;
        font-optical-sizing: auto;
        font-weight: 200;
        z-index: 1;
        font-style: normal;
        align-items: center;
    }

    .content{
        display: flex;
        @media (max-width: 780px) {
            flex-direction: column;
        }
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        width: 80%;
        padding: 0 0 1.5rem 0;
        box-sizing: border-box;

        @media (max-width: 780px) {
            width: 100%;
            padding: 0 2rem 1.5rem 2rem;
        }
    }

    .section-title {
        font-family: "Albert Sans", serif;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: #888;
        white-space: nowrap;
        margin: 0;
    }

    .section-line {
        flex: 1;
        height: 1px;
        background: linear-gradient(to right, #ccc, transparent);
    }
    .container {
        width: 80%;
        height: auto;
        background: rgb(249, 249, 249);
        z-index: 3;
        padding: 2rem 0;
        @media (max-width: 780px) {
            width: 100%;
            padding: 1rem 0;
            margin-bottom: 2rem;
        }
    }
</style>