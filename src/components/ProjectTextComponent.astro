---
import TechStackComponent from "./TechStackComponent.astro";
const { projectTextProps } = Astro.props;
---

<div class="container">
    <div class="text">
        <h2 class="title">{projectTextProps.title}</h2>
        <TechStackComponent technologies={projectTextProps.techstach} />
        <span class="description">{projectTextProps.description}</span>
        {projectTextProps.githubUrl && (
            <a href={projectTextProps.githubUrl} target="_blank" rel="noopener noreferrer" class="github-badge">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="#ffffff" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                </svg>
                <span>GitHub</span>
            </a>
        )}
    </div>
</div>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Albert+Sans:ital,wght@0,300;1,300&family=Poiret+One&display=swap');

    .container {
        width: 50%;
        height: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        font-family: "Albert Sans", serif;
        font-optical-sizing: auto;
        font-weight: 200;
        color: #a9a9a9;
        background: #1a1a2e;
        flex-shrink: 0;
        box-sizing: border-box;

        @media (max-width: 780px) {
            width: 100%;
            height: auto;
            padding: 2.5rem 0;
        }
    }

    .text {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        width: 65%;
        gap: 1.4rem;
        letter-spacing: 0.05em;

        @media (max-width: 780px) {
            width: 85%;
            gap: 1.2rem;
        }
    }

    .title {
        font-size: 1.05rem;
        font-weight: 700;
        color: #e8e8f0;
        position: relative;
        display: inline-block;
        margin: 0;
        letter-spacing: 0.15em;

        @media (max-width: 780px) {
            font-size: 0.95rem;
        }
    }

    .title::after {
        content: '';
        position: absolute;
        width: 0;
        height: 1px;
        bottom: -3px;
        left: 0;
        background-color: #6c63ff;
        transition: width 1.3s ease;
    }

    .container:hover .title::after {
        width: 100%;
    }

    .description {
        font-size: 0.82rem;
        width: 100%;
        word-wrap: break-word;
        overflow-wrap: break-word;
        line-height: 1.8;
        color: #9a9ab0;

        @media (max-width: 780px) {
            font-size: 0.76rem;
        }
    }

    .github-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        background: #21262d;
        color: #e6edf3;
        padding: 0.4rem 0.85rem;
        border-radius: 2rem;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-decoration: none;
        border: 1px solid #30363d;
        transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.4);
        width: fit-content;

        @media (max-width: 780px) {
            font-size: 0.68rem;
            padding: 0.35rem 0.75rem;
        }
    }

    .github-badge:hover {
        background: #30363d;
        border-color: #6e7681;
        transform: translateY(-2px);
        color: #ffffff;
        box-shadow: 0 3px 10px rgba(0, 0, 0, 0.5);
    }

    .github-badge svg {
        flex-shrink: 0;
    }
</style>
