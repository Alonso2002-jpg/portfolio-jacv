---
import LineTitle from "./LineTitle.astro";
import OriginLogo from "../assets/logorigin.jpg"
import {useTranslations} from "../i18n/utils";
import {languageList} from "../i18n/ui";

const { currentLang } = Astro.props
const t = useTranslations(currentLang as keyof typeof languageList)

const projects = [
    {
        icon: "🧠",
        titleKey: "expAiTitle",
        descKey: "expAiDesc",
        stack: "Python (FastAPI), IA/LLMs, Laravel, Angular, React",
        infra: "AWS (S3, EC2, Lambda, SQS, SNS, CloudWatch), CI/CD Jenkins, Docker",
        items: ["expAiItem1", "expAiItem2", "expAiItem3", "expAiItem4", "expAiItem5"],
    },
    {
        icon: "💳",
        titleKey: "expSaasTitle",
        descKey: "expSaasDesc",
        stack: "Laravel (PHP), Next.js (React)",
        infra: "Docker, NGINX, MinIO, GitHub Actions, Vercel",
        items: ["expSaasItem1", "expSaasItem2", "expSaasItem3"],
    },
    {
        icon: "📊",
        titleKey: "expEmsTitle",
        descKey: "expEmsDesc",
        stack: ".NET (C#), Angular (Tailwind, PrimeNG)",
        infra: "Docker, CI/CD, servidores dedicados",
        items: ["expEmsItem1", "expEmsItem2", "expEmsItem3", "expEmsItem4"],
    },
]
---

<div class="exp-container">
    <div class="section-header">
        <h2 class="section-title">{t("sectionExperience")}</h2>
        <div class="section-line"></div>
    </div>

    <div class="container">
        <!-- Company card -->
        <div class="company-card">
            <div class="company-header">
                <img src={OriginLogo.src} alt="OriginPath logo" class="company-logo" />
                <div class="company-info">
                    <span class="company-name">OriginPath</span>
                    <span class="company-role">{t("expRole")}</span>
                    <span class="company-period">{t("expPeriod")}</span>
                </div>
                <span class="badge-current">{t("expCurrent")}</span>
            </div>
            <p class="company-desc">{t("expCompanyDesc")}</p>
        </div>

        <!-- Projects list -->
        <div class="projects-list">
            {projects.map((proj) => (
                <div class="project-item">
                    <div class="project-header">
                        <span class="project-icon">{proj.icon}</span>
                        <LineTitle title={t(proj.titleKey as any)} />
                    </div>
                    <p class="project-desc">{t(proj.descKey as any)}</p>
                    <ul class="project-items">
                        {proj.items.map((item) => (
                            <li>{t(item as any)}</li>
                        ))}
                    </ul>
                    <div class="stack-row">
                        <span class="stack-label">Stack:</span>
                        <span class="stack-value">{proj.stack}</span>
                    </div>
                    <div class="stack-row">
                        <span class="stack-label">{t("expInfra")}:</span>
                        <span class="stack-value">{proj.infra}</span>
                    </div>
                </div>
            ))}
        </div>
    </div>
</div>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Albert+Sans:ital,wght@0,300;1,300&family=Poiret+One&display=swap');

    .exp-container {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        font-family: "Albert Sans", serif;
        font-weight: 200;
        z-index: 1;
        min-height: 100%;
        margin-bottom: 2rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        width: 80%;
        padding: 0 0 1.5rem 0;
        box-sizing: border-box;
        @media (max-width: 780px) {
            width: 100%;
            padding: 0 2rem 1.5rem 2rem;
        }
    }

    .section-title {
        font-family: "Albert Sans", serif;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: #888;
        white-space: nowrap;
        margin: 0;
    }

    .section-line {
        flex: 1;
        height: 1px;
        background: linear-gradient(to right, #ccc, transparent);
    }

    .container {
        width: 80%;
        background: rgb(249, 249, 249);
        z-index: 3;
        padding: 2rem 0 2rem 4rem;
        display: flex;
        flex-direction: column;
        gap: 2rem;
        @media (max-width: 780px) {
            width: 100%;
            padding: 1rem 2rem;
        }
    }

    /* Company card */
    .company-card {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        border-left: 2px solid rgba(58, 72, 82, 0.15);
        padding-left: 1.2rem;
    }

    .company-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .company-logo {
        width: 36px;
        height: 36px;
        object-fit: contain;
        border-radius: 6px;
        opacity: 0.85;
    }

    .company-info {
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
    }

    .company-name {
        font-size: 0.95rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        color: #3A4852;
    }

    .company-role {
        font-size: 0.72rem;
        opacity: 0.7;
        text-transform: uppercase;
        letter-spacing: 0.12em;
    }

    .company-period {
        font-size: 0.65rem;
        opacity: 0.45;
        letter-spacing: 0.08em;
    }

    .badge-current {
        font-size: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        border: 1px solid rgba(58, 72, 82, 0.45);
        padding: 0.25rem 0.8rem;
        border-radius: 20px;
        color: #3A4852;
        opacity: 0.75;
        margin-right: 1rem;
        font-weight: 600;
        @media (max-width: 780px) {
            margin-left: 0;
            margin-right: 0;
        }
    }

    .company-desc {
        font-size: 0.75rem;
        opacity: 0.65;
        max-width: 680px;
        line-height: 1.6;
        margin: 0;
    }

    /* Projects list */
    .projects-list {
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
        padding-left: 1.2rem;
        border-left: 2px solid rgba(58, 72, 82, 0.08);
    }

    .project-item {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .project-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .project-icon {
        font-size: 1rem;
        line-height: 1;
    }

    .project-desc {
        font-size: 0.75rem;
        opacity: 0.65;
        max-width: 680px;
        line-height: 1.6;
        margin: 0;
        padding-left: 4%;
    }

    .project-items {
        list-style: none;
        padding: 0 0 0 calc(4% + 0.5rem);
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .project-items li {
        font-size: 0.72rem;
        opacity: 0.6;
        line-height: 1.5;
        position: relative;
        padding-left: 0.9rem;
    }

    .project-items li::before {
        content: "–";
        position: absolute;
        left: 0;
        opacity: 0.5;
    }

    .stack-row {
        display: flex;
        gap: 0.4rem;
        padding-left: 4%;
        flex-wrap: wrap;
    }

    .stack-label {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        opacity: 0.4;
        font-weight: 700;
    }

    .stack-value {
        font-size: 0.65rem;
        opacity: 0.5;
        letter-spacing: 0.04em;
    }

    @media (max-width: 780px) {
        .exp-container {
            margin-bottom: 1.25rem;
        }
    }
</style>

