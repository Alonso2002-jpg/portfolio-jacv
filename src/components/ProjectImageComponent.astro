---
const { projectImageProps } = Astro.props;
---

<div class="container">
    <div class="image-container"></div>
</div>

<style define:vars={{panaderiaBG: `url(${projectImageProps.image.src})`, gradiante: projectImageProps.imgBg}}>
    .container {
        width: 50%;
        height: 100%;
        min-height: 380px;
        display: flex;
        background: var(--gradiante);
        justify-content: center;
        align-items: center;
        opacity: 1;
        transition: opacity .7s ease-in-out;
        flex-shrink: 0;

        @media (max-width: 780px) {
            width: 100%;
            height: 280px;
            min-height: unset;
        }
    }

    .image-container {
        width: 70%;
        height: 65%;
        min-height: 220px;
        background-image: var(--panaderiaBG);
        background-color: rgba(0, 0, 0, 0.19);
        background-size: contain;
        background-repeat: no-repeat;
        background-position: center;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.19), 6px 6px 6px rgba(0, 0, 0, 0.23);

        @media (max-width: 780px) {
            width: 85%;
            height: 100%;
            min-height: unset;
        }
    }

    .container:hover {
        opacity: .75;
    }
</style>
